{
  "name": "logitux-web",
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:cloud": "concurrently \"npm run dev:cloud:server\" \"npm run dev:client\"",
    "dev:cloud:server": "MOCK_MODE=true tsx watch server/index.ts",
    "build": "vite build",
    "start": "node dist/server/index.js",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose",
    "electron:dev": "concurrently \"npm run dev:server\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:compile": "tsc -p tsconfig.electron.json && printf '{\"type\":\"commonjs\"}' > dist-electron/package.json",
    "electron:build": "npm run build && npm run electron:compile && electron-builder --linux",
    "electron:build:deb": "npm run build && npm run electron:compile && electron-builder --linux deb",
    "electron:build:rpm": "npm run build && npm run electron:compile && electron-builder --linux rpm",
    "electron:build:appimage": "npm run build && npm run electron:compile && electron-builder --linux AppImage"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "better-sqlite3": "^12.6.2",
    "classnames": "^2.5.1",
    "express": "^5.1.0",
    "i18next": "^24.2.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.474.0",
    "react-i18next": "^15.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "wait-on": "^9.0.4"
  }
}
