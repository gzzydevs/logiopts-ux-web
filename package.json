{
  "name": "logitux-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node dist/server/index.js",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "classnames": "^2.5.1",
    "express": "^5.1.0",
    "i18next": "^24.2.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.474.0",
    "react-i18next": "^15.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "jest": "^30.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
